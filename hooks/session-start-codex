#!/usr/bin/env sh
set -eu

SCRIPT_DIR=$(CDPATH= cd "$(dirname "$0")" && pwd)
PLUGIN_ROOT=${PLUGIN_ROOT:-$(CDPATH= cd "$SCRIPT_DIR/.." && pwd)}
export PLUGIN_ROOT

node <<'JS'
const pluginRoot = process.env.PLUGIN_ROOT;
const cpCli = `node "${pluginRoot}/bin/coding-plugins.js"`;
const context = [
  "You are using coding-plugins: a Chinese-first coding workflow plugin with English agent-facing skills.",
  "",
  "CLI fallback available in this session; no global coding-plugins command is required:",
  `CP_CLI: ${cpCli}`,
  "When `coding-plugins` is not on PATH, prefer `${CP_CLI} <command> ...`. Only suggest `coding-plugins cli install` or `${CP_CLI} cli install` when the user explicitly needs a terminal shortcut.",
  "",
  "Before any coding-related task, read and use `coding-plugins:using-coding-plugins`. It classifies the direct intent and development workflow, then routes to the matching skill.",
  "",
  "Default main workflow:",
  "1. For new requirements, unclear contracts, schemas, state machines, or unclear acceptance criteria, use SDD through `spec-driven-development`.",
  "2. When approved specs need landing, write `writing-technicals`, then `writing-test-cases`, then `writing-plans`, and keep Spec ID -> Test -> Task -> Evidence traceability.",
  "3. For behavior changes, use TDD: RED, then GREEN, then REFACTOR, and record evidence in `docs/coding-plugins/features/<feature-name>/evidences/<doc-id>-VED.md`.",
  "4. Before claiming completion, fixed status, or passing status, run `verification-before-completion` and provide command evidence.",
  "5. When the user asks to commit or chooses commit during finishing, use `using-git-commit`. Commit-message language follows the user's choice; ask if unspecified. Use an `Authored-by` footer and do not add AI authors.",
  "6. When a branch or task is complete, use `finishing-a-development-branch` for commit prompting, PR/merge/keep/cleanup choices.",
  "",
  "If the user only asks to query, explain, read, or report status, do not force the development workflow; answer the query directly.",
].join("\n");

process.stdout.write(JSON.stringify({
  hookSpecificOutput: {
    hookEventName: "SessionStart",
    additionalContext: context,
  },
}));
JS
