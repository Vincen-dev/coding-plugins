#!/usr/bin/env sh
set -eu

SCRIPT_DIR=$(CDPATH= cd "$(dirname "$0")" && pwd)
PLUGIN_ROOT=${PLUGIN_ROOT:-$(CDPATH= cd "$SCRIPT_DIR/.." && pwd)}
export PLUGIN_ROOT

node <<'JS'
const pluginRoot = process.env.PLUGIN_ROOT;
const cpCli = `node "${pluginRoot}/bin/coding-plugins.js"`;
const context = [
  "你正在使用 coding-plugins 中文编码工作流插件。",
  "",
  "本次可用 CLI fallback（无需安装全局 coding-plugins 命令）：",
  `CP_CLI: ${cpCli}`,
  "当终端没有 `coding-plugins` 命令时，优先使用 `${CP_CLI} <command> ...`；只有用户明确需要终端快捷命令时，才提示运行 `coding-plugins cli install` 或 `${CP_CLI} cli install`。",
  "",
  "开始任何编码相关任务前，优先读取并使用 `coding-plugins:using-coding-plugins`。它负责判断直接意图和开发任务类型，再路由到对应 skill。",
  "",
  "默认主链路：",
  "1. 新需求、契约不清、schema、状态机或验收标准不清时，先走 SDD：`spec-driven-development`。",
  "2. 已批准规格需要落地时，先写 `writing-technicals` 技术文档，再写 `writing-test-cases` 测试用例和 `writing-plans` 实现计划，并保持 Spec ID -> Test -> Task -> Evidence 可追踪。",
  "3. 实现行为改动时，走 TDD：先 RED，再 GREEN，再 REFACTOR，并把 TED 写入 `docs/coding-plugins/features/<feature-name>/evidences/<doc-id>-TED.md`。",
  "4. 声称完成、修复或通过前，运行 `verification-before-completion` 并给出命令证据。",
  "5. 用户要求提交或完成阶段选择提交时，使用 `git-commit`，提交信息按用户选择使用中文或英文 Conventional Commit；用户未指定语言时先询问，footer 使用 `Authored-by: Vincen <hx001007@gmail.com>`，不得加入 AI 作者。",
  "6. 分支或任务完成时，使用 `finishing-a-development-branch` 处理提交提示、PR/merge/保留/清理选择。",
  "",
  "如果用户只是查询、解释、读取或要求状态，不要强行进入开发链路；直接完成查询即可。",
].join("\n");

process.stdout.write(JSON.stringify({
  hookSpecificOutput: {
    hookEventName: "SessionStart",
    additionalContext: context,
  },
}));
JS
