{
  "name": "@vincen-dev/coding-plugins",
  "version": "1.2.0",
  "description": "Chinese-first coding workflow plugin with English agent-facing skills for Codex, Claude Code, Gemini CLI and local skills clients.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "coding-plugins": "./bin/coding-plugins.js"
  },
  "scripts": {
    "build": "node dist/src/cli/release/build-dist.js",
    "command-registry:ts": "node src/cli/command-registry.ts",
    "test": "npm run preflight",
    "test:ts": "npm run preflight",
    "typecheck": "tsc --noEmit",
    "agent-pressure-harness:ts": "node src/cli/agent-pressure-harness.ts",
    "agent-pressure-ingest:ts": "node src/cli/agent-pressure-ingest.ts",
    "bump-version:ts": "node src/cli/bump-version.ts",
    "decision-points:ts": "node skills/using-coding-plugins/scripts/decision-points.ts",
    "doctor:ts": "node src/cli/doctor.ts",
    "document-contract-migration:ts": "node skills/document-metadata/scripts/document-contract-migration.ts",
    "execution-contract:ts": "node src/cli/execution-contract.ts",
    "inject:ts": "node src/cli/inject.ts",
    "install-copilot:ts": "node src/cli/install-copilot.ts",
    "install-cursor:ts": "node src/cli/install-cursor.ts",
    "list:ts": "node src/cli/list.ts",
    "manifest-check:ts": "node src/cli/manifest-check.ts",
    "preflight": "node src/cli/preflight.ts",
    "preflight:ts": "node src/cli/preflight.ts",
    "prepare-release:ts": "node src/cli/prepare-release.ts",
    "remote-audit:ts": "node src/cli/remote-audit.ts",
    "security-audit:ts": "node src/cli/security-audit.ts",
    "scaffold-feature-docs:ts": "node skills/spec-driven-development/scripts/scaffold-feature-docs.ts",
    "scaffold-fixture-case:ts": "node skills/writing-skills/scripts/scaffold-fixture-case.ts",
    "subagent-prompt-builder:ts": "node skills/subagent-driven-development/scripts/subagent-prompt-builder.ts",
    "validate:ts": "node src/cli/validate.ts",
    "validate-spec:ts": "node skills/spec-driven-development/scripts/validate-spec.ts",
    "validate-technicals:ts": "node skills/writing-technicals/scripts/validate-technicals.ts",
    "validate-tdd-evidence:ts": "node skills/test-driven-development/scripts/validate-tdd-evidence.ts",
    "workflow-brief:ts": "node src/cli/workflow-brief.ts",
    "workflow-guard:ts": "node src/cli/workflow-guard.ts",
    "workflow-mode:ts": "node skills/using-coding-plugins/scripts/workflow-mode.ts",
    "workflow-state:ts": "node src/cli/workflow-state.ts"
  },
  "files": [
    "bin/",
    "dist/",
    "skills/",
    "hooks/",
    "assets/",
    ".codex-plugin/",
    ".claude-plugin/",
    ".opencode/",
    ".agents/skills",
    "plugin.json",
    "gemini-extension.json",
    "GEMINI.md",
    "INSTALL.md",
    "SECURITY.md",
    "README.md",
    "LICENSE",
    "RELEASE-NOTES.md",
    "!skills/**/scripts/fixtures/",
    "!skills/**/scripts/fixtures/**",
    "!**/__pycache__/",
    "!**/*.py",
    "!**/*.pyc"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=22.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0"
  },
  "license": "MIT",
  "author": {
    "name": "Vincen",
    "email": "hx001007@gmail.com",
    "url": "https://github.com/Vincen-dev"
  },
  "homepage": "https://github.com/Vincen-dev/coding-plugins",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vincen-dev/coding-plugins.git"
  },
  "keywords": [
    "coding",
    "skills",
    "sdd",
    "tdd",
    "codex",
    "claude-code",
    "gemini-cli",
    "opencode",
    "workflow",
    "chinese"
  ]
}
